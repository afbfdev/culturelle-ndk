generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Submission {
  id             String              @id @default(uuid())
  date           DateTime            @default(now())
  nom            String
  prenom         String
  kamil          Int[]
  // Champ texte hérité (ancien formulaire). Conservé pour ne pas perdre de données.
  zikrs          String?             @db.Text
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  xassidaEntries SubmissionXassida[]
  zikrEntries    SubmissionZikr[]

  @@index([nom, prenom])
  @@index([createdAt])
}

model Xassida {
  id                String             @id @default(cuid())
  slug              String             @unique
  label             String             @unique
  description       String?            @db.Text
  isActive          Boolean            @default(true)
  sortOrder         Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  submissionEntries SubmissionXassida[]

  @@index([isActive, sortOrder])
}

model SubmissionXassida {
  id           String     @id @default(cuid())
  submissionId String
  xassidaId    String
  quantity     Int
  createdAt    DateTime   @default(now())
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  xassida      Xassida    @relation(fields: [xassidaId], references: [id], onDelete: Restrict)

  @@unique([submissionId, xassidaId])
  @@index([submissionId])
  @@index([xassidaId, createdAt])
}

model SubmissionZikr {
  id           String     @id @default(cuid())
  submissionId String
  label        String
  quantity     Int
  createdAt    DateTime   @default(now())
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([label])
}
